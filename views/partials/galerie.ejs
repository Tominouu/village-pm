<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galerie - Village PM</title>
    <link rel="stylesheet" href="assets/css/galerie.css">
</head>
<body>
    <section class="galerie-section">
        <h1 class="titre-section">Designed to last</h1>
        <div class="galerie-caroussel">
            <div class="galerie-photo"><img src="assets/img/1.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/2.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/3.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/4.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/5.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/6.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/7.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/8.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/9.webp" alt=""></div>
            <div class="galerie-photo"><img src="assets/img/10.webp" alt=""></div>

        </div>

        <div class="loupe-clip">
            <div class="loupe-scale">
                <div class="galerie-caroussel">
                    <div class="galerie-photo"><img src="assets/img/1.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/2.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/3.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/4.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/5.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/6.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/7.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/8.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/9.webp" alt=""></div>
                    <div class="galerie-photo"><img src="assets/img/10.webp" alt=""></div>
                </div>
            </div>
        </div>

        <div class="lens-border"></div>

        <div class="buttons-gallery">
            <button class="gallery-btn" id="prev-btn"><img src="assets/img/arrow.svg" alt="Flèche gauche" class="fleche-gauche"></button>
            <button class="gallery-btn" id="next-btn"><img src="assets/img/arrow.svg" alt="Flèche droite" class="fleche-droite"></button>
        </div>
    </section>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="assets/js/galerie.js"></script>
</body>
</html>